# Moneybird MCP (primary integration method - REQUIRED)
MCP_SERVER_URL=https://moneybird.com/mcp/v1/read_write
MCP_SERVER_AUTH_TOKEN=your_bearer_token

# Moneybird (recommended)
MONEYBIRD_ADMINISTRATION_ID=your_admin_id

# Moneybird OAuth (optional, for REST API fallback only)
MONEYBIRD_CLIENT_ID=your_client_id
MONEYBIRD_CLIENT_SECRET=your_client_secret
MONEYBIRD_ACCESS_TOKEN=your_access_token

# OpenAI (REQUIRED)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1

# Confidence Thresholds (optional, defaults shown)
CONFIDENCE_AUTO_THRESHOLD=95
CONFIDENCE_REVIEW_THRESHOLD=80

# Amount threshold for manual review in cents (optional, default: 100000 = €1000)
AMOUNT_REVIEW_THRESHOLD=100000

# Scheduler (optional, default: hourly)
CRON_SCHEDULE=0 * * * *

# Maximum invoices processed per scheduled run (optional, default: 10)
MAX_INVOICES_PER_RUN=10

# Maximum retries after a failed Moneybird/MCP call (optional, default: 3, 0 disables)
MCP_MAX_RETRIES=3

# Database (optional, default shown)
DATABASE_PATH=./data/moneybird-agent.db

# Logging (optional, default: info)
LOG_LEVEL=info

# Email Notifications (optional - auto-detected if configured)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_TO=recipient1@example.com,recipient2@example.com

# WhatsApp Notifications (optional - auto-detected if configured)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=+14155238886
WHATSAPP_TO=+1234567890,+0987654321

# Telegram Notifications (optional - auto-detected if configured)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_IDS=your_chat_id,another_chat_id

# Daily Summary Time (optional, default: 08:00 UTC = 09:00 Amsterdam winter, 10:00 summer)
# Format: "HH:MM" in UTC timezone
# Note: Amsterdam is UTC+1 (winter/CET) or UTC+2 (summer/CEST)
# For 09:00 Amsterdam: use "08:00" in winter, "07:00" in summer
DAILY_SUMMARY_TIME=08:00

# Unmatched Transactions Check lookback in days (optional, default: 90)
UNMATCHED_TRANSACTIONS_DAYS=90

# Overdue sales invoice tracking in the daily summary (optional, default: true)
OVERDUE_INVOICES_ENABLED=true

# Quarterly BTW (VAT) preparation reminder on the 1st of Jan/Apr/Jul/Oct (optional, default: true)
BTW_REMINDER_ENABLED=true

# Monthly financial report on the 1st of each month (optional, default: true)
MONTHLY_REPORT_ENABLED=true
